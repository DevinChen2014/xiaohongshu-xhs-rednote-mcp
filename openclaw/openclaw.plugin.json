{
  "id": "xhs-insights-openclaw",
  "name": "XHS Insights MCP for OpenClaw",
  "description": "OpenClaw native plugin shim for the hosted read-only XHS Insights MCP service.",
  "version": "0.1.6",
  "providers": ["xhs-insights"],
  "providerAuthEnvVars": {
    "xhs-insights": ["SOCIAL_MEDIA_MCP_API_KEY"]
  },
  "activation": {
    "onStartup": false,
    "onCapabilities": ["tool"]
  },
  "setup": {
    "requiresRuntime": false
  },
  "contracts": {
    "tools": [
      "xhs-insights__xhs_search_notes",
      "xhs-insights__xhs_get_note_detail_by_note_url",
      "xhs-insights__xhs_get_note_detail_by_note_id",
      "xhs-insights__xhs_get_note_comments_by_note_id",
      "xhs-insights__xhs_get_note_comments_by_note_url",
      "xhs-insights__xhs_get_note_sub_comments_by_comment_id",
      "xhs-insights__xhs_get_user_info_by_user_id",
      "xhs-insights__xhs_get_user_info_by_profile_url",
      "xhs-insights__xhs_get_user_posted_notes_by_user_id",
      "xhs-insights__xhs_get_user_posted_notes_by_profile_url"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKeyEnv": {
        "type": "string",
        "default": "SOCIAL_MEDIA_MCP_API_KEY",
        "description": "Environment variable that contains the API Key used as a Bearer token."
      },
      "endpointUrl": {
        "type": "string",
        "format": "uri",
        "default": "https://mcp.52choujiang.com/xhs/mcp",
        "description": "Remote streamable-http MCP endpoint URL."
      },
      "connectionTimeoutMs": {
        "type": "integer",
        "default": 30000,
        "minimum": 1000,
        "maximum": 120000,
        "description": "Timeout in milliseconds for remote MCP HTTP requests."
      }
    }
  }
}
