      "xhs-insights__xhs_get_user_posted_notes_by_profile_url"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "connectionTimeoutMs": {
        "type": "integer",
        "default": 30000,
        "minimum": 1000,
        "maximum": 120000,
        "description": "Timeout in milliseconds for remote MCP HTTP requests."
      }
    }
  },
  "configUiHints": {
    "connectionTimeoutMs": {
      "label": "Connection timeout",
