      },
      "primaryEnv": "SOCIALDATAX_API_KEY",
      "networkTargets": ["https://mcp.52choujiang.com"]
    }
  },
  "requires": {
    "bins": ["node"],
    "env": ["SOCIALDATAX_API_KEY"]
  },
  "primaryEnv": "SOCIALDATAX_API_KEY",
  "networkTargets": ["https://mcp.52choujiang.com"],
  "environment": {
    "binaries": ["node"],
    "externalServices": [
      {
        "name": "mcp.52choujiang.com"
      }
    ]
  },
  "contracts": {
    "tools": [
      "xhs-insights__xhs_get_search_hot_list",
      "xhs-insights__xhs_search_notes",
      "xhs-insights__xhs_get_note_detail_by_note_url",
      "xhs-insights__xhs_get_note_detail_by_note_id",
      "xhs-insights__xhs_get_note_comments_by_note_id",
      "xhs-insights__xhs_get_note_comments_by_note_url",
      "xhs-insights__xhs_get_note_sub_comments_by_comment_id",
