{
  "id": "xhs-insights-openclaw-plugin",
  "name": "社媒数据助手 小红书 MCP | Xiaohongshu XHS RedNote MCP",
  "description": "SocialDataX / 社媒数据助手 为小红书 / Xiaohongshu / XHS / RedNote 提供社媒研究支持：搜索热榜、笔记搜索、评论分析、笔记详情、评论回复、博主信息和博主笔记。",
  "version": "0.1.17",
  "providers": ["xhs-insights"],
  "providerAuthEnvVars": {
    "xhs-insights": ["SOCIALDATAX_API_KEY"]
  },
  "providerAuthChoices": [
    {
      "provider": "xhs-insights",
      "method": "api-key",
      "choiceId": "socialdatax-api-key",
      "choiceLabel": "SocialDataX API Key",
      "choiceHint": "Used only to authorize requests to the hosted XHS Insights MCP service.",
      "groupId": "socialdatax",
      "groupLabel": "SocialDataX / 社媒数据助手",
      "optionKey": "socialDataxApiKey",
      "cliFlag": "--socialdatax-api-key",
      "cliOption": "--socialdatax-api-key <key>",
      "cliDescription": "SOCIALDATAX_API_KEY used by the hosted MCP service.",
      "onboardingScopes": ["social-media-research"],
      "assistantPriority": 0
    }
  ],
  "activation": {
    "onStartup": false,
    "onCapabilities": ["tool"]
  },
  "runtimeRequirements": {
    "bins": ["node"],
    "env": ["SOCIALDATAX_API_KEY"],
    "primaryEnv": "SOCIALDATAX_API_KEY",
    "networkTargets": ["https://mcp.52choujiang.com"]
  },
  "metadata": {
    "xhs-insights": {
      "requires": {
        "bins": ["node"],
